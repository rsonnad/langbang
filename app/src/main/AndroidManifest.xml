<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Dev-only permissions (WRITE_SECURE_SETTINGS adb-wifi helper,
         REQUEST_INSTALL_PACKAGES + RECEIVE_BOOT_COMPLETED for the R2 sideload
         self-update) are declared in src/debug/AndroidManifest.xml so they are
         merged into debug builds only and never ship in a Play release. -->

    <uses-feature
        android:name="android.hardware.microphone"
        android:required="true" />

    <application
        android:name=".LangbangApplication"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Langbang"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:screenOrientation="sensorLandscape"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <property
                android:name="android.window.PROPERTY_COMPAT_ALLOW_RESTRICTED_RESIZABILITY"
                android:value="true" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- AdbWifiBootReceiver (BOOT_COMPLETED adb-wifi helper) is debug-only;
             see src/debug/AndroidManifest.xml. -->

        <receiver
            android:name=".ExternalNowVoicingReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.sponic.langbangml.DRIVE_NOW_VOICING" />
            </intent-filter>
        </receiver>

        <!-- FileProvider (serves the downloaded update.apk to the installer) is
             debug-only; see src/debug/AndroidManifest.xml. -->

    </application>

</manifest>
